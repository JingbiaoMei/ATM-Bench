{
  "vector_store": {
    "provider": "chroma",
    "config": {
      "collection_name": "mem0",
      "path": "output/QA_Agent/Mem0/mem0_chroma"
    }
  },
  "llm": {
    "provider": "openai",
    "config": {
      "model": "gpt-4o-mini",
      "temperature": 0.1,
      "max_tokens": 1000,
      "api_key": "${OPENAI_API_KEY}"
    }
  },
  "embedder": {
    "provider": "openai",
    "config": {
      "model": "text-embedding-3-small",
      "api_key": "${OPENAI_API_KEY}"
    }
  },
  "history_db_path": "output/QA_Agent/Mem0/mem0_history.db"
}
